# Copy this file to `.env.local` for local dev. Both files live outside git
# (see .gitignore). The CI build reads VITE_TMDB_API_KEY from the GitHub
# Actions secret of the same name.

# TMDB v3 read-only API key. Reuse the same key the sibling widgets in
# QuizShow (apps/bacon-trail, apps/widget) consume.
VITE_TMDB_API_KEY=your-tmdb-v3-key-here
